<?xml version="1.0" encoding="utf-8"?>
<com.youngmanapp.overlay.DismissableTouchFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 사장님 정책 (v37 2026-05-23): 흰 풀스크린 loading. 풀스크린 흰 배경
         + 캐릭터/별/로딩바/텍스트 가운데. v34 native loading_card 부활하되
         사장님 디자인 명시 (흰 배경) 반영. CallPostActivity click 시 즉시
         normal_card → loading_card 토글 (16ms 안 반응). -->
    <FrameLayout
        android:id="@+id/overlay_loading_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI 요약중..."
                android:textColor="#1F1F23"
                android:textSize="21sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:id="@+id/loading_character_wrap"
                android:layout_width="165dp"
                android:layout_height="165dp">

                <ImageView
                    android:id="@+id/loading_character_image"
                    android:layout_width="165dp"
                    android:layout_height="165dp"
                    android:src="@drawable/loading_secretary"
                    android:scaleType="fitCenter"
                    android:contentDescription="loading" />

                <TextView
                    android:id="@+id/loading_star_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="13dp"
                    android:layout_marginTop="8dp"
                    android:text="✨"
                    android:textSize="22sp"
                    android:alpha="0" />

                <TextView
                    android:id="@+id/loading_star_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginEnd="17dp"
                    android:layout_marginTop="17dp"
                    android:text="✨"
                    android:textSize="22sp"
                    android:alpha="0" />

                <TextView
                    android:id="@+id/loading_star_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="33dp"
                    android:text="✨"
                    android:textSize="22sp"
                    android:alpha="0" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="205dp"
                android:layout_height="4dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/loading_bar_track"
                android:clipChildren="true">

                <View
                    android:id="@+id/loading_bar_indicator"
                    android:layout_width="72dp"
                    android:layout_height="4dp"
                    android:background="@drawable/loading_bar_indicator" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="잠시만 기다려주세요"
                android:textColor="#1F1F23"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="내용을 정리하고 있어요"
                android:textColor="#7A7A80"
                android:textSize="13sp"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <TextView
            android:id="@+id/loading_close_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/loading_close_bg"
            android:gravity="center"
            android:text="×"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/overlay_normal_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_gravity="center"
        app:cardCornerRadius="14dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:contentPadding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/overlay_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:drawableEnd="@drawable/ic_heart_red"
                    android:drawablePadding="6dp"
                    android:text="영맨 고객관리 비서"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:id="@+id/overlay_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:letterSpacing="-0.01" />

                <LinearLayout
                    android:id="@+id/overlay_group_picker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginBottom="6dp"
                        android:text="양식을 전송할 그룹"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:letterSpacing="-0.01" />

                    <LinearLayout
                        android:id="@+id/overlay_group_chip"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/chip_dropdown_plain"
                        android:paddingHorizontal="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_folder_filled"
                            android:tint="#666666"
                            android:contentDescription="group" />

                        <TextView
                            android:id="@+id/overlay_group_chip_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:textColor="#111111"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:singleLine="true"
                            android:ellipsize="end" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_chevron_down"
                            android:tint="#888888"
                            android:contentDescription="open" />
                    </LinearLayout>

                    <ScrollView
                        android:id="@+id/overlay_group_list_scroll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:maxHeight="180dp"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/overlay_group_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/group_list_bg" />
                    </ScrollView>
                </LinearLayout>

                <!-- 사장님 정책 (v54 2026-05-24): 모달 자동 종료 카운트다운.
                     일반 사용자에게 "모달" 표현 X — "팝업창" 으로 표시. 매 초
                     remaining 갱신. 위치 = 그룹 chip 아래 + 버튼 row 위. -->
                <TextView
                    android:id="@+id/overlay_dismiss_countdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:textColor="#111111"
                    android:textSize="13sp"
                    android:letterSpacing="-0.01" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E5E5" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/overlay_btn_cancel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="취소"
                    android:textColor="#FF3B30"
                    android:textSize="15sp"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#E5E5E5" />

                <!-- 사장님 정책 (v42 2026-05-23): "양식에 전송" 버튼 부활.
                     A 방식 — 한 번 누르면 자동으로 STT + confirm 까지 진행
                     (사용자 무개입). autoSubmitTask 가 trigger_summarize → polling
                     → confirm 자동 처리. -->
                <TextView
                    android:id="@+id/overlay_btn_review"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="요약보기"
                    android:textColor="#0066FF"
                    android:textSize="15sp"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#E5E5E5" />

                <TextView
                    android:id="@+id/overlay_btn_submit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="양식에 전송"
                    android:textColor="#0066FF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</com.youngmanapp.overlay.DismissableTouchFrameLayout>
