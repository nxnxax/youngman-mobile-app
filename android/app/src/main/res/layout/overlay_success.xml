<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="80dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="@drawable/glass_card_stroke"
        app:cardCornerRadius="22dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:contentPadding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingTop="22dp"
            android:paddingBottom="20dp">

            <ImageView
                android:id="@+id/success_check"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_check_circle_filled"
                android:contentDescription="success" />

            <TextView
                android:id="@+id/success_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="양식 전송 완료"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
